# === Supabase PostgreSQL ===
# Transaction pooler URL (for app queries via PgBouncer)
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection URL (for Prisma migrations — bypasses pooler)
DIRECT_URL="postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# === Supabase (Auth + Storage) ===
# Found in: Supabase dashboard → Settings → API
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
# Bucket for movie posters and media — create in Supabase dashboard → Storage
SUPABASE_STORAGE_BUCKET=cinema-storage

# === API ===
PORT=3001
NODE_ENV=development

# === Frontend: Customer site (apps/web) ===
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
WEB_FRONTEND_URL=http://localhost:3000
OAUTH_ALLOWED_REDIRECT_ORIGINS=http://localhost:3000,http://localhost:3002

# === Frontend: Admin dashboard (apps/admin) ===
# NEXT_PUBLIC_API_URL and NEXT_PUBLIC_SUPABASE_* same values as above
ADMIN_FRONTEND_URL=http://localhost:3002

# === GitHub Actions Secrets (set in GitHub repo settings, not here) ===
# RENDER_API_KEY
# RENDER_STAGING_SERVICE_ID
# RENDER_PROD_SERVICE_ID
# VERCEL_TOKEN
# VERCEL_ORG_ID
# VERCEL_WEB_PROJECT_ID       <- Vercel project ID for apps/web
# VERCEL_ADMIN_PROJECT_ID     <- Vercel project ID for apps/admin
